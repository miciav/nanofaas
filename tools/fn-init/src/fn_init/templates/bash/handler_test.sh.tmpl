#!/usr/bin/env bash
# Unit tests for {{FUNCTION_NAME}} handler.
# Run: bash tests/test_handler.sh

set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
HANDLER="$SCRIPT_DIR/../handler.sh"
PASS=0; FAIL=0

assert_eq() {
    local desc="$1" expected="$2" actual="$3"
    if [ "$actual" = "$expected" ]; then
        echo "  PASS: $desc"
        ((PASS++))
    else
        echo "  FAIL: $desc"
        echo "    expected: $expected"
        echo "    actual:   $actual"
        ((FAIL++))
    fi
}

echo "=== {{FUNCTION_NAME}} handler tests ==="

result=$(echo '{"input":{"key":"value"}}' | bash "$HANDLER")
assert_eq "valid input returns result" \
    "$(echo '{"result":"ok"}' | jq -c .)" \
    "$(echo "$result" | jq -c .)"

result=$(echo '{"input":"not-an-object"}' | bash "$HANDLER")
assert_eq "non-object input returns error" \
    "error" \
    "$(echo "$result" | jq -r 'keys[0]')"

echo ""
echo "Results: $PASS passed, $FAIL failed"
[ "$FAIL" -eq 0 ]
