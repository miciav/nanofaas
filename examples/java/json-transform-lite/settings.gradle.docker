pluginManagement {
    repositories {
        gradlePluginPortal()
        mavenCentral()
    }
}

plugins {
    id 'org.gradle.toolchains.foojay-resolver-convention' version '1.0.0'
}

rootProject.name = 'nanofaas'

include('common')
include(':sdks:java-lite');   project(':sdks:java-lite').projectDir = file('sdks/java-lite')
include('examples:java:json-transform-lite')
